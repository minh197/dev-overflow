# =============================================================================
# Devoverflow – copy to .env and fill in real values. Do not commit .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Prisma) – used by packages/database and apps/api
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://dev:devpassword@localhost:5433/devoverflow?schema=public"

# -----------------------------------------------------------------------------
# Next.js / NextAuth (apps/web)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# OAuth – Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth – GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Legacy names still supported by the API for compatibility:
# GITHUB_ID=""
# GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# NestJS API (apps/api)
# -----------------------------------------------------------------------------
JWT_SECRET="your-jwt-secret-min-32-chars"
# Must match NEXT_PUBLIC_API_URL host + port (e.g. both 3001, or both 3002).
PORT=3001
# Browsers allowed to send credentials (cookies). Default in code is http://localhost:3000
# when unset. Add comma-separated origins if you also use http://127.0.0.1:3000 or a LAN URL.
# CORS_ORIGIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# Frontend → API (apps/web)
# -----------------------------------------------------------------------------
# Must match PORT above, e.g. http://localhost:3001
NEXT_PUBLIC_API_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# Search (optional Typesense; default SEARCH_ENGINE=postgres)
# -----------------------------------------------------------------------------
SEARCH_ENGINE="postgres"
# SEARCH_ENGINE="typesense"
# SEARCH_TYPESENSE_FALLBACK="true"

# Required for Typesense when SEARCH_ENGINE=typesense (or for reindex:search).
# Local Docker (`docker compose up typesense`) — key must match docker-compose.yml:
TYPESENSE_HOST="localhost"
TYPESENSE_PORT="8110"
TYPESENSE_PROTOCOL="http"
TYPESENSE_API_KEY="devoverflow-typesense-dev-key"

# Typesense Cloud: set host to your cluster node, TYPESENSE_PORT=443, TYPESENSE_PROTOCOL=https,
# TYPESENSE_API_KEY to the admin API key from the dashboard (never commit real keys).
